@model CEGA.Models.ViewModels.VerPlanoViewModel

@{
    ViewData["Title"] = "Ver Plano";
}

<h2>@Model.Plano.NombreArchivo</h2>

<!--  Botón para abrir el panel lateral -->
<button class="btn btn-secondary mb-3" type="button" data-bs-toggle="offcanvas" data-bs-target="#panelLateral" aria-controls="panelLateral">
    Ver anotaciones y tareas
</button>

<!--  PDF viewer -->
<!-- Contenedor posicionable -->
<div id="pdf-container" style="position: relative; width: 100%; height: 600px;">
    <embed src="@Model.Plano.RutaArchivo" type="application/pdf" style="width:100%; height:100%;" />
</div>

<!--  Panel lateral (Offcanvas de Bootstrap) -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="panelLateral" aria-labelledby="panelLateralLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="panelLateralLabel">Anotaciones y tareas</h5>
        <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
    </div>
    <div class="offcanvas-body">
        @await Component.InvokeAsync("AnotacionesTareas", new { planoId = Model.Plano.Id })
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
    <script>
               document.addEventListener("DOMContentLoaded", function () {
            const pdfContainer = document.getElementById("pdf-container");

            pdfContainer.addEventListener("click", function (e) {
                const rect = pdfContainer.getBoundingClientRect();
                const x = ((e.clientX - rect.left) / rect.width) * 100;
                const y = ((e.clientY - rect.top) / rect.height) * 100;

                const texto = prompt("Ingrese su anotación:");
                if (texto && texto.trim() !== "") {
                    guardarAnotacion(@Model.Plano.Id, x, y, texto.trim());
                }
            });

                    function guardarAnotacion(planoId, x, y, texto) {
            const pdfContainer = document.getElementById("pdf-container");

            html2canvas(pdfContainer, {
                x: (x / 100) * pdfContainer.offsetWidth,
                y: (y / 100) * pdfContainer.offsetHeight,
                width: 150,
                height: 150,
                scale: 1
            }).then(canvas => {
                const imagenBase64 = canvas.toDataURL("image/png");

                fetch('/Pdf/GuardarComentario', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        PlanoId: planoId,
                        CoordenadaX: x,
                        CoordenadaY: y,
                        Texto: texto,
                        ImagenBase64: imagenBase64 // este campo debes agregarlo al modelo si aún no existe
                    })
                })
                .then(response => {
                    if (response.ok) {
                        fetch(`/Pdf/PanelLateralPartial/${planoId}`)
                            .then(res => res.text())
                            .then(html => {
                                document.querySelector('#panelLateral .offcanvas-body').innerHTML = html;
                            });
                    } else {
                        alert("Error al guardar la anotación.");
                    }
                })
                .catch(error => {
                    console.error("Error en la petición:", error);
                    alert("Ocurrió un error al guardar la anotación.");
                });
            });
        }

        });

        // Estas dos funciones deben estar FUERA para que se usen desde el HTML
        function enfocarElemento(elem) {
            if (!elem) return;

            const container = document.getElementById('pdf-container');

            const previsualizacion = document.createElement('div');
            previsualizacion.className = 'preview-box';
            previsualizacion.style.position = 'absolute';
            previsualizacion.style.left = elem.style.left;
            previsualizacion.style.top = elem.style.top;
            previsualizacion.style.width = '130px';
            previsualizacion.style.height = '130px';
            previsualizacion.style.border = '3px solid #3498db';
            previsualizacion.style.backgroundColor = '#fff';
            previsualizacion.style.boxShadow = '0 0 10px rgba(0,0,0,0.3)';
            previsualizacion.style.zIndex = 9999;
            previsualizacion.style.padding = '4px';
            previsualizacion.innerHTML = elem.outerHTML;

            container.appendChild(previsualizacion);

            setTimeout(() => {
                previsualizacion.remove();
            }, 4000);
        }

        function enfocarPorId(id) {
            const elemento = document.getElementById(id);
            enfocarElemento(elemento);
        }

    </script>
}
