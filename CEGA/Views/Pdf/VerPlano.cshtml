@model CEGA.Models.Plano
@{
    ViewData["Title"] = "Visualizar Plano";
}

<h2>Visualizar Plano - @Model.Disciplina</h2>

<div class="mb-3">
    <p><strong>Nombre del archivo:</strong> @Model.NombreArchivo</p>
    <p><strong>Fecha de subida:</strong> @Model.FechaSubida.ToString("dd/MM/yyyy")</p>
</div>

<iframe src="@Model.RutaArchivo" width="100%" height="600px" style="border: 1px solid #ccc;"></iframe>

<div class="mt-3">
    <a asp-action="ListaPlanos" class="btn btn-secondary">Volver a la lista</a>
</div>
